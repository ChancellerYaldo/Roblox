--Recoil
local TotalValue = 0
local ShotNumber = 0

local function RecoilReset()

	local StartShotNumber = ShotNumber
	task.wait(.2)
	
	if StartShotNumber == ShotNumber then

		local StartTotalValue = TotalValue
		for i = 1, 15 do
			if ShotNumber ~= StartShotNumber then
				break
			end

			Y -= StartTotalValue/15
			TotalValue -= StartTotalValue/15

			if i == 15 then
				TotalValue = 0
			end
			task.wait()
		end

	end
end

local function Clipping(TargetCameraCFrame, LeftOfCamera)
	Character = Player.Character
	local Origin = Character.Head.Position
	local CameraPosition = TargetCameraCFrame.Position

	local RightOfCamera = (TargetCameraCFrame * CFrame.new(1, 0, 0)).Position
	local LeftOfCamera = (TargetCameraCFrame * CFrame.new(LeftOfCamera, 0, 0)).Position

	local Direction1 = (RightOfCamera - Origin).Unit
	local Direction2 = (LeftOfCamera - Origin).Unit

	local Parameters = RaycastParams.new()
	Parameters.FilterDescendantsInstances = {Character}
	Parameters.CollisionGroup = "Characters"

	local Distance = (CameraPosition - Origin).Magnitude + .5

	local Result1 = workspace:Raycast(Origin, Direction1 * Distance, Parameters)	 	
	local Result2 = workspace:Raycast(Origin, Direction2 * Distance, Parameters)

	local CFrameLookAtHead
	local x, y, z = TargetCameraCFrame:ToOrientation()
	local MainDistance
	if Result1 and Result2 then
		if Result1.Distance < Result2.Distance then
			MainDistance = Result1.Distance
			CFrameLookAtHead = CFrame.lookAt(CameraPosition, Character.Head.Position)
		else
			MainDistance = Result2.Distance
			CFrameLookAtHead = CFrame.lookAt(CameraPosition, Character.Head.Position)
		end
	elseif Result1 then
		MainDistance = Result1.Distance
		CFrameLookAtHead = CFrame.lookAt(CameraPosition, Character.Head.Position)
	elseif Result2 then			
		MainDistance = Result2.Distance
		CFrameLookAtHead = CFrame.lookAt(CameraPosition, Character.Head.Position)
	end
	if MainDistance then
		local OffsetForward = CFrame.new(0, 0, -(Distance - MainDistance))
		local NewCameraPosition = (CFrameLookAtHead * OffsetForward).Position			
		TargetCameraCFrame = CFrame.lookAt(NewCameraPosition, Character.Head.Position)
	end
	return TargetCameraCFrame
end

local function HasProperty(Object, PropertyName)
	local Success, Result = pcall(function()
		return Object[PropertyName]
	end)

	return Success and true
end

local TransparencyConnection

local function CharacterTransparency(TargetTransparency)
	Character = Player.Character
	
	local function a(v)
		if HasProperty(v, "LocalTransparencyModifier") and (not v.Parent:IsA("Model") or v.Parent == Character) then
			TweenService:Create(v, TweenInfo.new(.15, Enum.EasingStyle.Sine), {LocalTransparencyModifier = TargetTransparency}):Play()
		end
	end
	
	for i, v in pairs(Character:GetDescendants()) do
		a(v)
	end
	
	if TransparencyConnection then
		TransparencyConnection:Disconnect()
	end
	TransparencyConnection = Character.DescendantAdded:Connect(a)
end

local CustomCamera = {}

function CustomCamera.Sensitivity(Multiplier)
	if Multiplier then
		CurrentXSM *= Multiplier
		CurrentYSM *= Multiplier
	else
		CurrentXSM = DefaultXSM
		CurrentYSM = DefaultYSM
	end
end

function CustomCamera.XRecoil()
	local Val = Gun.Recoil.Value.X
	Gun.Recoil.Value = Vector3.new(0, Gun.Recoil.Value.Y, 0)
	for i = 1, 5 do
		X += Val/5
		task.wait()
	end
end

function CustomCamera.YRecoil()
	if Gun.Recoil.Value.Y > 0 then
		ShotNumber += 1

		local Val = Gun.Recoil.Value.Y
		Gun.Recoil.Value = Vector3.new(Gun.Recoil.Value.X, 0, 0)

		TotalValue += Val

		coroutine.wrap(function()
			for i = 1, 5 do
				Y += Val/5
				task.wait()
			end
		end)()

		RecoilReset()
	end
end

local ShiftlockedOffset = Vector3.new(2, 2, 7)

local XDriftMin = -2
local XDriftMax = 2
local YDriftMin = -2
local YDriftMax = 2

local BaseMult = 12
local CustomSwayZVal = -10
local BaseSway = 1.5 -- Speed
local SetSway = 1.5 -- Distance
local BaseFreq = 15 -- view bobbing frequency
local SetFreq = .12
local BaseNumLerp = .25
CustomCamera.DriftX = 0
CustomCamera.DriftY = 0
CustomCamera.BobbingYValue = 0
local Velocity = 0


CustomCamera.InThirdPerson = false
CustomCamera.InFirstPerson = false


CustomCamera.LeaningLeft = false
CustomCamera.LeaningRight = false
CustomCamera.LeaningValue = 0

function NumLerp(Start, Goal, Alpha)
	return Start + (Goal - Start) * Alpha
end

function GetMouseDrift(Drift, MouseDelta, DeltaTime)
	return NumLerp(Drift.X, math.clamp(MouseDelta.X, XDriftMin, XDriftMax), (BaseMult * DeltaTime)), NumLerp(Drift.Y, math.clamp(MouseDelta.Y, YDriftMin, YDriftMax), (BaseMult * DeltaTime))
end

function GetSwayVal(x:number, y:number) : CFrame
	return CFrame.new(Vector3.new(x, y, 0), Vector3.new(x * .95, y * .95, CustomSwayZVal)) + Camera.CFrame.Position
end

function GetVelocity() : number
	return math.round(Vector3.new(HRP.AssemblyLinearVelocity.X, HRP.AssemblyLinearVelocity.Y, HRP.AssemblyLinearVelocity.Z).Magnitude)
end

function CalculateCurve(Base : number, Set : number) : number
	return math.sin(os.clock() * Base) * Set
end

