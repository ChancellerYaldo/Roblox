function CustomCamera.CameraCFrame(DeltaTime)
	Character = Player.Character
	
	local Tool = Character:FindFirstChildWhichIsA("Tool")
	local ConfigurationModule = Tool and Tool:FindFirstChild("GunStuff") and Tool.GunStuff:FindFirstChildWhichIsA("ModuleScript")
	local Configuration = ConfigurationModule and require(ConfigurationModule)
	local NewOffset = MainOffset.Value

	if CustomCamera.InThirdPerson then
		NewOffset = ShiftlockedOffset

		if Configuration then
			if Gun.Aiming then		
				NewOffset = Configuration.AimingOffset	
			else		
				NewOffset = Configuration.HipfiringOffset
			end			
		end
	elseif CustomCamera.InFirstPerson then
		NewOffset = FirstPersonOffset
	else
		NewOffset = Vector3.new(0, FirstPersonOffset.Y, ZOffset.Value)
	end
	
	local HeightOffset = (HRP.Position - Character.Torso.Position).Magnitude
	NewOffset += Vector3.new(0, -HeightOffset * 1.25, 0)
	
	if NewOffset ~= OffsetTweeningTo then
		CustomCamera.ChangeOffset(NewOffset)
	end	
	
	local NewFOV = DefaultFOV
	if CustomCamera.InFirstPerson and Configuration and Gun.Aiming then
		NewFOV *= Configuration.FOVAimMultiplier
	end
	
	if Movement.RealSprinting then
		NewFOV = math.clamp(NewFOV * 1.1, DefaultFOV, 10000)
	end
	
	if Movement.Sliding then
		NewFOV *= 1.3
	end
	
	FOVTweeningTo = NewFOV
	Camera.FieldOfView = Lerp(Camera.FieldOfView, NewFOV, .1)
	
	if CustomCamera.InFirstPerson then
		--print(GetVelMag())
		Velocity = NumLerp(Velocity, GetVelocity(), BaseNumLerp)		
	end
	
	local StartCFrame = CFrame.new(HRP.Position)
		* CFrame.Angles(0, math.rad(X), 0) 
		* CFrame.Angles(math.rad(Y), 0, 0)
		* CFrame.new(CustomCamera.ShakeOffset.Value + Gun.ShootShakeOffset.Value)
	
	
	if CustomCamera.InThirdPerson or CustomCamera.InFirstPerson then
		HRP.CFrame = HRP.CFrame:Lerp(CFrame.new(HRP.Position) * CFrame.Angles(0, math.rad(X), 0), LerpValue)
		if CustomCamera.InFirstPerson then	
			if not Movement.Sliding then
				CustomCamera.BobbingYValue = CalculateCurve(BaseFreq, SetFreq) * Velocity / BaseMult
			else
				CustomCamera.BobbingYValue = 0
			end
	
			--print(math.floor(CustomCamera.BobbingYValue * 100) / 100)
			StartCFrame *= CFrame.new(0, CustomCamera.BobbingYValue * .25, 0) --Bobbing
		end
			
		local CameraFocus = StartCFrame * CFrame.new(MainOffset.Value.X, MainOffset.Value.Y, -10000)
		local CameraCFrame = StartCFrame * CFrame.new(MainOffset.Value)

		if CustomCamera.InThirdPerson then
			CameraCFrame = Clipping(CameraCFrame, -.5)
		end
		
		local TargetCFrame = CFrame.new(CameraCFrame.Position, CameraFocus.Position)
		
		if CustomCamera.InFirstPerson and not Lockpick.Lockpicking then
			--Tilt
			TargetCFrame *= CustomCamera.TorsoTilt
			
			--Drift
			local MouseDelta = UIS:GetMouseDelta()
			local DriftX, DriftY = GetMouseDrift(Vector2.new(CustomCamera.DriftX, CustomCamera.DriftY), MouseDelta, DeltaTime)
			CustomCamera.DriftX = DriftX
			CustomCamera.DriftY = DriftY
			TargetCFrame *= CFrame.Angles(0, 0, math.rad(DriftX))
			
			--Sway
			if not Gun.Aiming then
				local Time = os.clock()
				local Sway = GetSwayVal(math.cos(Time * BaseSway) * SetSway, math.sin(Time * BaseSway) * SetSway)
				local X2, Y2, Z2 = Sway:ToEulerAnglesXYZ()
				TargetCFrame *= CFrame.Angles(X2, Y2, Z2)
			end
		end
		
		MouseIcon()
		--if CustomCamera.LeaningLeft then
		--	CustomCamera.LeaningValue = NumLerp(CustomCamera.LeaningValue, 20, .2)
		--elseif CustomCamera.LeaningRight then
		--	CustomCamera.LeaningValue = NumLerp(CustomCamera.LeaningValue, -20, .2)			
		--else
		--	CustomCamera.LeaningValue = NumLerp(CustomCamera.LeaningValue, 0, .2)
		--end
		
		Camera.CFrame = TargetCFrame
		--UIS.MouseBehavior = Enum.MouseBehavior.LockCenter
	else			
		local CameraCFrame = StartCFrame * CFrame.new(MainOffset.Value)
		Camera.CFrame = Camera.CFrame:Lerp(Clipping(CameraCFrame, -1), 1) -- .5 
	end
end

function CustomCamera.ChangeOffset(NewOffset)
	OffsetTweeningTo = NewOffset
	TweenService:Create(MainOffset, TweenInfo.new(.05, Enum.EasingStyle.Sine), {Value = NewOffset}):Play()
end

local StaticZ = ZOffset.Value

function CustomCamera.Zoom(_, State, Input)
	if State.Name == "Change" then
		if not CustomCamera.InFirstPerson and not CustomCamera.InThirdPerson then
			StaticZ = math.clamp(StaticZ - Input.Position.Z * 5, 5, 50)
			TweenService:Create(ZOffset, TweenInfo.new(.14, Enum.EasingStyle.Quad), {Value = StaticZ}):Play()
		end
	end
end


function CustomCamera.LockMouse(_, State, Input)
	if not CustomCamera.InThirdPerson and not CustomCamera.InFirstPerson then
		if State.Name == "Begin" then
			UIS.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
		elseif State.Name == "End" then
			UIS.MouseBehavior = Enum.MouseBehavior.Default
		end
	end
end

function CustomCamera.MouseInput(_, State, Input)
	if State.Name == "Change" then	
		Y = math.clamp(Y - Input.Delta.Y * CurrentYSM, -80, 80)
		X -= Input.Delta.X * CurrentXSM

		if CustomCamera.InThirdPerson or CustomCamera.InFirstPerson then
			if TotalValue ~= 0 then
				if Input.Delta.Y > 0 then
					TotalValue = math.clamp(TotalValue - Input.Delta.Y * CurrentYSM, 0, 10000000)
				end
			end
		end
	end
end

local function GetCameraOffset()
	local StartCFrame = CFrame.new((HRP.Position)) 
		* CFrame.Angles(0, math.rad(X), 0) 
		* CFrame.Angles(math.rad(Y), 0, 0)
	local CameraOffset = StartCFrame:ToObjectSpace(Camera.CFrame)
	return CameraOffset
end

