function Lerp(Start, Goal, Alpha)
	return Start + (Goal - Start) * Alpha
end

function CustomCamera.StartThirdPerson()
	if not CustomCamera.InThirdPerson then
		if not CustomCamera.InFirstPerson then
			OriginalOffset = MainOffset.Value
		else
			OriginalOffset = OriginalFirstPersonOffset
		end

		Humanoid.AutoRotate = false
		CustomCamera.InFirstPerson = false
		CharacterTransparency(0)
		CustomCamera.InFirstPerson = false
		CustomCamera.InThirdPerson = true
		--MouseIcon()
		
		coroutine.wrap(function()
			LerpValue = 0
			for i = 1, 10 do
				LerpValue = Lerp(LerpValue, GENERAL_LERP_VALUE, i / 10)
				task.wait(.07)
			end
		end)()

		MainOffset.Value = GetCameraOffset().Position
	end
end

function CustomCamera.EndThirdPerson()
	CustomCamera.InThirdPerson = false
	End()
	TweenService:Create(MainOffset, TweenInfo.new(.15, Enum.EasingStyle.Sine), {Value = OriginalOffset}):Play()
end

function CustomCamera.ThirdPerson(_, State)
	Character = Player.Character
	if State.Name == "Begin" and not Character:FindFirstChildWhichIsA("Tool") then
		if not CustomCamera.InThirdPerson then
			CustomCamera.StartThirdPerson()
		else
			CustomCamera.EndThirdPerson()
		end
	end
end

function CustomCamera.FirstPerson(_, State)
	if State.Name == "Begin" then
		CustomCamera.InFirstPerson = not CustomCamera.InFirstPerson

		if CustomCamera.InFirstPerson then

			if not CustomCamera.InThirdPerson then
				OriginalFirstPersonOffset = MainOffset.Value
			else
				CustomCamera.InThirdPerson = false
				OriginalFirstPersonOffset = OriginalOffset
			end

			--MouseIcon()
			CharacterTransparency(1)
		else			
			End()
			
			local Tool = Character:FindFirstChildWhichIsA("Tool") 

			if Tool then
				task.wait()
				CustomCamera.StartThirdPerson()
			end
		end
	end
end

function CustomCamera.LeanLeft(_, State)
	if State.Name == "Begin" then
		CustomCamera.LeaningLeft = not CustomCamera.LeaningLeft
		CustomCamera.LeaningRight = false
	end
end

function CustomCamera.LeanRight(_, State)
	if State.Name == "Begin" then
		CustomCamera.LeaningRight = not CustomCamera.LeaningRight
		CustomCamera.LeaningLeft = false
	end
end

return CustomCamera
