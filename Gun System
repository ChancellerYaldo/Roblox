local MaterialHealths = {
	Player = 33,
	Metal = 101,
	Brick = 101,
	Concrete = 101,
	Wood = 50,
	Plastic = 40,
	SmoothPlastic = 40,
	Neon = 30,
	Fabric = 20,
	Glass = 10,
	Sand = 10,
	Mud = 10,
}

local function GetHealth(CurrentHealth, MaterialName)
	return CurrentHealth - (MaterialHealths[MaterialName] or 75)
end

local MouseDistance = 1000000000

local function HeadCheck(Hit)
	--print(Hit.Name)
	--if Hit.Parent:IsA("Accessory") then
		--print(Hit.AccessoryWeld.Part1, Hit.Name)
	--end
	return (Hit.Parent:IsA("Accessory") and Hit.AccessoryWeld.Part1 == Hit:FindFirstAncestorOfClass("Model").Head) or Hit == Hit:FindFirstAncestorOfClass("Model").Head
end

local function GetDamage(Hit, Tool, Configuration)
	--local BaseDamage = Configuration.Damage.Body.Value

	--if (Hit.Parent:IsA("Accessory") and Hit.Parent) or Hit.Name == "Head" then
	--	BaseDamage = Configuration.Damage.Head.Value
	--end
	--if Configuration.ShootTypes.Shotgun.Value then
	--	local Distance = (Hit.Position - Tool.Handle.FirePoint.WorldPosition).Magnitude
	--	local Multiplier = 4
	--	BaseDamage = math.floor(math.pow(math.pow(BaseDamage, Multiplier + 5) / math.pow(Distance, Multiplier), 1/(Multiplier + 2)))
	--end
		

	local Damage = Configuration.BodyDamage --BaseDamage
	
	if HeadCheck(Hit) then
		Damage = Configuration.HeadDamage
	end
	
	if Configuration.ShootType == "Shotgun" then
		local MaxRange = 40 --this number indicates the maximum range within the base damage shouldn't change
		local Distance = (Hit.Position - Tool.Handle.FirePoint.WorldPosition).Magnitude
		Damage = math.floor(math.clamp(Damage / math.clamp(Distance / MaxRange, 1, 2), 1, Damage))
	end

	return Damage
	
end

local function HasProperty(Object, PropertyName)
	local Success, Result = pcall(function()
		return Object[PropertyName]
	end)
	
	return Success and true
end

local function CheckForLowAmmo(Current, OutOf)
	local Player = not RunService:IsServer() and game.Players.LocalPlayer
	if Player then
		local LowAmmo = Player.PlayerGui.Ammo.LowAmmo
		if Current / OutOf <= .25 then
			TweenService:Create(LowAmmo.ImageLabel, TweenInfo.new(.1), {ImageTransparency = 0}):Play()
			TweenService:Create(LowAmmo.TextLabel, TweenInfo.new(.1), {TextTransparency = 0}):Play()
			LowAmmo.ImageLabel.ImageTransparency = 0
			LowAmmo.TextLabel.TextTransparency = 0
			Player.PlayerGui.Ammo.LowAmmo.TextLabel.Text = Current		
			LowAmmo.Visible = true
			local OriginalSize = UDim2.fromScale(1, 1)
			LowAmmo.TextLabel.Size = UDim2.fromScale(OriginalSize.X.Scale * 1.5, OriginalSize.Y.Scale * 1.5)
			TweenService:Create(LowAmmo.TextLabel, TweenInfo.new(.1), {Size = OriginalSize}):Play()
			local TI = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 1)
			TweenService:Create(LowAmmo.ImageLabel, TI, {ImageTransparency = 1}):Play()
			TweenService:Create(LowAmmo.TextLabel, TI, {TextTransparency = 1}):Play()
		end
	end
end

local function IsAlive(Humanoid)
	local IsPlayer = game.Players:GetPlayerFromCharacter(Humanoid.Parent)
	local Health = (IsPlayer or not Humanoid.Parent:GetAttribute("Health")) and Humanoid.Health or Humanoid.Parent:GetAttribute("Health")
	--print(IsPlayer, Humanoid.Health, Humanoid.Parent:GetAttribute("Health"))
	return Health > 0 and Health
end

