local ContextActionService = game:GetService("ContextActionService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local IS_CLIENT = RunService:IsClient()
local RNG = Random.new()
local nextClientId = 0

local modulesFolder = ReplicatedStorage:WaitForChild("Modules")
local gunFramework = ReplicatedStorage:WaitForChild("GunFramework")

local CustomCamera
local CrosshairModule

if IS_CLIENT then
	CustomCamera = require(modulesFolder:WaitForChild("CustomCamera"))
	CrosshairModule = require(modulesFolder:WaitForChild("Crosshair"))
end

local GunEffects = require(script:WaitForChild("GunEffects"))
local General = require(modulesFolder:WaitForChild("General"))

local MAX_RAY_DISTANCE = 1000
local DEFAULT_BULLET_STRENGTH = 100
local MAX_PENETRATIONS = 8
local DEFAULT_MATERIAL_RESISTANCE = 75

local CROSSHAIR_START_SIZE = UDim2.fromScale(0.051, 0.088)
local CROSSHAIR_PEAK_SIZE = UDim2.fromScale(0.051 * 2, 0.088 * 2)
local CROSSHAIR_MIN_SIZE = UDim2.fromScale(0.051 * 0.75, 0.088 * 0.75)

local MINIGUN_START_DEBOUNCE = 0.18
local MINIGUN_DEBOUNCE_STEP = 0.01
local MINIGUN_MAX_TORQUE = 5

-- These values represent how much penetration strength a bullet loses after passing through
-- a target or material. The same table therefore controls both whether penetration is allowed
-- and how much strength remains for the next recursive ray.
local MATERIAL_RESISTANCE = {
	Player = 33,
	Metal = 101,
	Brick = 101,
	Concrete = 101,
	Wood = 50,
	Plastic = 40,
	SmoothPlastic = 40,
	Neon = 30,
	Fabric = 20,
	Glass = 10,
	Sand = 10,
	Mud = 10,
}

local Gun = {}

Gun.Ammo = {
	Light = 200,
	Medium = 300,
}

-- Kept for compatibility with any UI or external code that already reads this field.
-- Individual weapon clients still save and restore their own magazine value on equip/unequip.
Gun.CurrentBullets = 0

local ClientTemplate = {}
ClientTemplate.__index = ClientTemplate
ClientTemplate.Enemies = {}
ClientTemplate.PlayerClients = {}

Gun.ClientTemplate = ClientTemplate

local function getMaterialResistance(materialName)
	return MATERIAL_RESISTANCE[materialName] or DEFAULT_MATERIAL_RESISTANCE
end

local function getRemainingBulletStrength(currentStrength, materialName)
	return currentStrength - getMaterialResistance(materialName)
end

local function playClientSound(sound, shouldPlay)
	if not IS_CLIENT then
		return
	end

	if shouldPlay then
		sound:Play()
		return
	end

	sound:Stop()
end

local function dispatchEffect(tool, character, ...)
	if IS_CLIENT then
		tool.GunStuff.Events.Other:FireServer(...)
		return
	end

	General.Other(character, ...)
end

local function runClientEffect(effectType, parameters)
	if not IS_CLIENT then
		return
	end

	local effectFunction = GunEffects[effectType]
	if not effectFunction then
		return
	end

	effectFunction(table.unpack(parameters))
end

local function isAutomaticShootType(shootType)
	return shootType == "Auto" or shootType == "Minigun"
end

local function getNumericValue(value, fallback)
	if type(value) == "number" then
		return value
	end

	if typeof(value) == "Instance" and value:IsA("ValueBase") then
		return value.Value
	end

	return fallback
end

local function setFrameProperty(container, propertyName, value)
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("Frame") then
			child[propertyName] = value
		end
	end
end

local function createClient(tool, character)
	local player = Players:GetPlayerFromCharacter(character)
	local client = setmetatable({}, ClientTemplate)

	nextClientId += 1
	client.Id = nextClientId
	client.Character = character
	client.Player = player
	client.Tool = tool
	client.Configuration = require(tool.GunStuff.Configuration)
	client.MainFrame = nil
	client.Reloading = false
	client.AimDebounce = false
	client.ShootDebounce = false
	client.MadeClickSoundForNoAmmo = false
	client.Equipping = false
	client.Equipped = false
	client.HoldingTrigger = false
	client.BurstDebounce = false
	client.ShotgunDebounce = false
	client.AutomaticLoopVersion = 0
	client.StoredBullets = client.Configuration.PerMag
	client.CurrentShootDebounce = client.Configuration.ShootDebounce

	if player then
		ClientTemplate.PlayerClients[tool] = client
	else
		table.insert(ClientTemplate.Enemies, client)
	end

	return client
end

local function createFallbackCamera(character)
	local cameraProxy = Instance.new("Part")
	cameraProxy.Size = Vector3.zero
	cameraProxy.Transparency = 1
	cameraProxy.Anchored = true
	cameraProxy.CanCollide = false
	cameraProxy.CanTouch = false
	cameraProxy.CanQuery = false
	cameraProxy.CFrame = character.Head.CFrame
	cameraProxy.Name = "Camera"
	cameraProxy.Parent = character

	return cameraProxy
end

local function getWeaponCamera(character)
	if IS_CLIENT and workspace.CurrentCamera then
		return workspace.CurrentCamera
	end

	return createFallbackCamera(character)
end

local function getTargetData(hitPart)
	local character = hitPart:FindFirstAncestorWhichIsA("Model")
	if not character then
		return nil
	end

	local humanoid = character:FindFirstChildWhichIsA("Humanoid")
	if not humanoid then
		return nil
	end

	return character, humanoid, Players:GetPlayerFromCharacter(character)
end

local function isFriendlyTarget(shooterPlayer, targetPlayer)
	if not shooterPlayer or not targetPlayer or not targetPlayer.Team then
		return false
	end

	return shooterPlayer.Team == targetPlayer.Team
end

local function passesNpcHitChance(client)
	if client.Player then
		return true
	end

	local enemyConfigModule = client.Character:FindFirstChildWhichIsA("ModuleScript")
	if not enemyConfigModule then
		return true
	end

	local enemyConfig = require(enemyConfigModule)
	return RNG:NextNumber() < (enemyConfig.HitChance or 1)
end

local function getHitFeedbackStyle(hitPart)
	if General.HeadCheck(hitPart) then
		return gunFramework.Sounds.Headshot, Color3.fromRGB(255, 255, 0)
	end

	return gunFramework.Sounds.Bodyshot, Color3.fromRGB(255, 255, 255)
end

local function getOrCreateDamageGui(targetRootPart, baseDamage)
	local gui = targetRootPart:FindFirstChild("DamageNumbers")

	if gui then
		gui:SetAttribute("Hits", (gui:GetAttribute("Hits") or 0) + 1)
		gui.TextLabel.Text = (tonumber(gui.TextLabel.Text) or 0) + baseDamage
		return gui
	end

	gui = gunFramework.DamageNumbers:Clone()
	gui.Adornee = targetRootPart
	gui.TextLabel.Text = baseDamage
	gui.Parent = targetRootPart
	gui:SetAttribute("Hits", 0)

	return gui
end

local function positionDamageGui(gui, shooterRootPart, targetRootPart)
	local shooterRotation = shooterRootPart.CFrame - shooterRootPart.Position
	local offsetFromTarget = CFrame.new(targetRootPart.Position) * shooterRotation
	local worldOffset = offsetFromTarget:ToWorldSpace(CFrame.new(2, 3, 0))

	gui.StudsOffsetWorldSpace = targetRootPart.CFrame:ToObjectSpace(worldOffset).Position
end

local function scheduleDamageGuiFade(gui)
	local startingHitCount = gui:GetAttribute("Hits")

	task.delay(1, function()
		if not gui.Parent then
			return
		end

		-- The Hits attribute acts as a generation counter. If another hit arrived during the
		-- delay, this callback is stale and must not destroy the refreshed damage display.
		if gui:GetAttribute("Hits") ~= startingHitCount then
			return
		end

		gui.Name = "Dead"
		TweenService:Create(
			gui.TextLabel,
			TweenInfo.new(0.25, Enum.EasingStyle.Linear),
			{TextTransparency = 1}
		):Play()

		task.delay(0.5, function()
			if gui.Parent then
				gui:Destroy()
			end
		end)
	end)
end

local function showDamageFeedback(client, targetCharacter, hitPart, baseDamage, hitDistance)
	if not IS_CLIENT then
		return
	end

	local targetHumanoid = targetCharacter:FindFirstChildWhichIsA("Humanoid")
	local targetRootPart = targetCharacter:FindFirstChild("HumanoidRootPart")
	local shooterRootPart = client.Character:FindFirstChild("HumanoidRootPart")

	if not targetHumanoid or not targetRootPart or not shooterRootPart then
		return
	end

	local currentHealth = General.IsAlive(targetHumanoid)
	if not currentHealth then
		return
	end

	local hitSound, textColor = getHitFeedbackStyle(hitPart)
	local gui = getOrCreateDamageGui(targetRootPart, baseDamage)

	positionDamageGui(gui, shooterRootPart, targetRootPart)
	gui.TextLabel.TextColor3 = textColor

	local size = math.clamp(hitDistance / 20, 1.5, 30)
	gui.Size = UDim2.fromScale(size, size)

	TweenService:Create(
		gui,
		TweenInfo.new(0.1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, 0, true),
		{Size = UDim2.fromScale(size * 1.33, size * 1.25)}
	):Play()

	scheduleDamageGuiFade(gui)

	-- Damage is applied through a remote/server path, so the target may still report its old
	-- health on this frame. Comparing current health with the pending damage predicts whether
	-- this hit will be lethal and lets the hit marker respond immediately without trusting the
	-- client to authoritatively decide death.
	client:Crosshair(hitPart, currentHealth <= baseDamage)
	playClientSound(hitSound, true)
end

local function applyCharacterDamage(client, targetHumanoid, hitPart)
	if IS_CLIENT then
		client.Tool.GunStuff.Events.Damage:FireServer(targetHumanoid, hitPart)
		return
	end

	General.Damage(client.Character, targetHumanoid, hitPart, client.Tool)
end

local function emitBloodEffects(client, targetCharacter, hitPosition)
	runClientEffect("BloodSplat", {client.Character, targetCharacter, hitPosition})
	dispatchEffect(
		client.Tool,
		client.Character,
		"BloodSplat",
		nil,
		nil,
		nil,
		nil,
		{client.Character, targetCharacter, hitPosition}
	)
end

local function processCharacterHit(client, result, direction, bulletStrength, hitDistance, penetrationDepth)
	local targetCharacter, targetHumanoid, targetPlayer = getTargetData(result.Instance)
	if not targetCharacter then
		return false
	end

	-- Returning true means the ray hit a character model even when damage is intentionally skipped.
	-- This prevents friendly characters or missed NPC shots from being treated as walls afterward.
	if isFriendlyTarget(client.Player, targetPlayer) then
		return true
	end

	if not passesNpcHitChance(client) then
		return true
	end

	local baseDamage = math.ceil(
		General.GetDamage(result.Instance, client.Tool, client.Configuration)
			* (bulletStrength / DEFAULT_BULLET_STRENGTH)
	)

	if baseDamage <= 0 then
		return true
	end

	applyCharacterDamage(client, targetHumanoid, result.Instance)
	showDamageFeedback(client, targetCharacter, result.Instance, baseDamage, hitDistance)
	emitBloodEffects(client, targetCharacter, result.Position)

	local resistance = getMaterialResistance("Player")
	if bulletStrength < resistance then
		return true
	end

	-- The complete model is ignored before the continuation ray so another limb from the same
	-- target cannot consume penetration strength a second time at nearly the same position.
	client:AddToParams(targetCharacter)
	client:FireRay(
		CFrame.new(result.Position),
		direction,
		getRemainingBulletStrength(bulletStrength, "Player"),
		penetrationDepth + 1
	)

	return true
end

local function canPenetrateSurface(hitPart, bulletStrength)
	if hitPart:GetAttribute("NoPenetration") then
		return false
	end

	return bulletStrength >= getMaterialResistance(hitPart.Material.Name)
end

local function processSurfaceHit(client, result, direction, bulletStrength, penetrationDepth)
	local hitPart = result.Instance
	local holeTemplate = gunFramework.Parts.BulletMark

	if canPenetrateSurface(hitPart, bulletStrength) then
		holeTemplate = gunFramework.Parts.SoftWallHole

		-- The current part is excluded before recursion. Without that exclusion, a ray beginning
		-- exactly on the impact surface can immediately hit the same part again and never advance.
		client:AddToParams(hitPart)
		client:FireRay(
			CFrame.new(result.Position),
			direction,
			getRemainingBulletStrength(bulletStrength, hitPart.Material.Name),
			penetrationDepth + 1
		)
	end

	local baseHoleCFrame = CFrame.new(result.Position, result.Position + result.Normal)
	local adjustedHoleCFrame = baseHoleCFrame
		* (holeTemplate:GetAttribute("CFrameAdjustment") or CFrame.new())

	runClientEffect("BulletHole", {holeTemplate, hitPart, adjustedHoleCFrame})
	dispatchEffect(
		client.Tool,
		client.Character,
		"BulletHole",
		nil,
		nil,
		{holeTemplate, hitPart, baseHoleCFrame}
	)
end

local function buildRaycastParams(client)
	client.Ignore = {client.Character}

	local rooms = workspace:FindFirstChild("Rooms")
	if rooms then
		for _, room in ipairs(rooms:GetChildren()) do
			local barriers = room:FindFirstChild("PathfindingBarriers")
			if barriers then
				table.insert(client.Ignore, barriers)
			end
		end
	end

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = client.Ignore
	client.Params = params
end

local function getSpreadRange(client)
	if RunService:IsServer() then
		local enemyConfigModule = client.Character:FindFirstChildWhichIsA("ModuleScript")
		if not enemyConfigModule then
			return 0, 0
		end

		local enemyConfig = require(enemyConfigModule)
		return enemyConfig.MinBloom or 0, enemyConfig.MaxBloom or 0
	end

	if client.Configuration.ShootType == "Shotgun" then
		local minSpread = getNumericValue(client.Configuration.MinSpread, 0)
		local maxSpread = getNumericValue(client.Configuration.MaxSpread, minSpread)

		if General.Aiming then
			minSpread = getNumericValue(client.Configuration.AimMinSpread, minSpread)
			maxSpread = getNumericValue(client.Configuration.AimMaxSpread, maxSpread)
		end

		return minSpread, maxSpread
	end

	local crosshair = client.Player
		and client.Player.PlayerGui:FindFirstChild("RealCrosshair")
		and client.Player.PlayerGui.RealCrosshair:FindFirstChild("Template")

	if not crosshair then
		return 0, 0
	end

	return 0, crosshair.Size.X.Scale * 5 * 0.95
end

local function getSpreadDirection(camera, minimumSpread, maximumSpread)
	if maximumSpread < minimumSpread then
		minimumSpread, maximumSpread = maximumSpread, minimumSpread
	end

	local directionCFrame = CFrame.lookAt(Vector3.zero, camera.CFrame.LookVector)
	local radialRotation = CFrame.fromOrientation(0, 0, math.rad(RNG:NextNumber(0, 360)))
	local spread = RNG:NextNumber(minimumSpread, maximumSpread)
	local spreadAngle = CFrame.fromOrientation(math.rad(spread), 0, 0)

	-- A random rotation around the forward axis chooses a direction on the spread circle, then
	-- the angular offset moves outward by the selected spread amount. This avoids biasing shots
	-- toward only horizontal or vertical directions.
	return (directionCFrame * radialRotation * spreadAngle).LookVector
end

local function fireProjectiles(client)
	local minimumSpread, maximumSpread = getSpreadRange(client)

	for _ = 1, client.Configuration.BulletsPerShot do
		local direction = getSpreadDirection(client.Camera, minimumSpread, maximumSpread)
		client:FireRay(nil, direction)
	end
end

local function updateCrosshairBloom(client)
	if not CrosshairModule then
		return
	end

	local bloomStrength = General.Aiming
		and client.Configuration.AimSpreadStrength
		or client.Configuration.HipfireSpreadStrength

	CrosshairModule.CrosshairDistance(bloomStrength)
end

local function playShotAnimation(client)
	General.PlayAnimationSet(client.Tracks, "Inspect", false)

	if General.Aiming then
		General.PlayAnimationSet(client.Tracks, "Shoot", true)
		return
	end

	General.PlayAnimationSet(client.Tracks, "HipFireShoot", true)
end

local function emitShotPresentation(client)
	local tool = client.Tool
	local character = client.Character

	playClientSound(tool.Handle.Audios.Gunshot, true)
	dispatchEffect(tool, character, "Sounds", nil, nil, nil, {tool.Handle.Audios.Gunshot, true})

	runClientEffect("Particles", {tool, client.Configuration.BulletsPerShot})
	dispatchEffect(tool, character, "Particles", nil, {tool, client.Configuration.BulletsPerShot})
end

local function stopShootShake(client)
	if not IS_CLIENT or not client.ShootShakeKey then
		return
	end

	RunService:UnbindFromRenderStep(client.ShootShakeKey)
	General.ShootShakeOffset.Value = Vector3.zero
end

local function startShootShake(client)
	if not IS_CLIENT then
		return
	end

	client.ShakeElapsed = 0
	RunService:UnbindFromRenderStep(client.ShootShakeKey)

	RunService:BindToRenderStep(client.ShootShakeKey, 1, function(deltaTime)
		client.ShakeElapsed += deltaTime

		if client.ShakeElapsed <= 0.04 then
			local currentTime = os.clock()
			local bobbleX = math.cos(currentTime * 30) * 0.4
			local bobbleY = math.abs(math.sin(currentTime * 4)) * 0.3
			local targetOffset = Vector3.new(bobbleX, bobbleY - 0.15, 0)
			local alpha = 1 - math.exp(-18 * deltaTime)

			General.ShootShakeOffset.Value = General.ShootShakeOffset.Value:Lerp(targetOffset, alpha)
			return
		end

		local alpha = 1 - math.exp(-16 * deltaTime)
		General.ShootShakeOffset.Value = General.ShootShakeOffset.Value:Lerp(Vector3.zero, alpha)

		-- Comparing an interpolated vector to exact zero can fail indefinitely because lerp
		-- approaches its target asymptotically. A small magnitude threshold gives the effect a
		-- deterministic stopping point and prevents a render-step callback from leaking forever.
		if General.ShootShakeOffset.Value.Magnitude > 0.001 then
			return
		end

		stopShootShake(client)
	end)
end

local function randomBetween(minimum, maximum)
	return RNG:NextNumber(minimum, maximum)
end

local function applyRecoil(client)
	local configuration = client.Configuration
	local horizontalDirection = RNG:NextNumber() > configuration.HorizontalStrength and 1 or -1
	local horizontalRecoil = randomBetween(configuration.HorizontalMin, configuration.HorizontalMax)
		* horizontalDirection
	local verticalRecoil = randomBetween(configuration.VerticalMin, configuration.VerticalMax)

	General.Recoil.Value = Vector3.new(horizontalRecoil, verticalRecoil, 0)
end

local function handleSniperPostShot(client)
	if client.Configuration.ShootType ~= "Sniper" then
		return
	end

	task.spawn(function()
		client.AimDebounce = true
		client:Unaim()
		task.wait(client.CurrentShootDebounce)
		client.AimDebounce = false

		if not IS_CLIENT or not client.Tool.Parent then
			return
		end

		if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
			client:Aim()
		end
	end)
end

local function handleEmptyMagazine(client)
	if client.MadeClickSoundForNoAmmo and isAutomaticShootType(client.Configuration.ShootType) then
		return
	end

	task.spawn(function()
		client.MadeClickSoundForNoAmmo = true
		playClientSound(client.Tool.Handle.Audios.NoAmmo, true)
		dispatchEffect(
			client.Tool,
			client.Character,
			"Sounds",
			nil,
			nil,
			nil,
			{client.Tool.Handle.Audios.NoAmmo, true}
		)
		client:Reload()
		client.MadeClickSoundForNoAmmo = false
	end)
end

local function canFire(client)
	if client.Reloading then
		return false
	end

	if not General.IsAlive(client.Character.Humanoid) then
		return false
	end

	if client.ShootDebounce and client.Configuration.ShootType ~= "Shotgun" then
		return false
	end

	return true
end

local function finishShotCooldown(client)
	if client.Configuration.ShootType ~= "Shotgun" then
		task.wait(client.CurrentShootDebounce)
	end

	client.ShootDebounce = false
	General.Shooting = false
end

local function loadTracks(client)
	local trackNames = {
		"Equip",
		"Unequip",
		"Idle",
		"Aim",
		"Shoot",
		"Reload",
		"HipFireShoot",
		"Inspect",
		"Jump",
		"Sprint",
	}

	local tracks = {}

	for _, animationName in ipairs(trackNames) do
		local normalTrack, armModelTrack = client:GetTracks(animationName)
		tracks[animationName .. "Track"] = normalTrack
		tracks["ArmModel" .. animationName .. "Track"] = armModelTrack
	end

	if RunService:IsServer() then
		tracks.WalkTrack = General.LoadTrack(
			ReplicatedStorage.Animations.Walk,
			client.Character.Humanoid
		)
	end

	return tracks
end

local function setTrackPriority(tracks, newPriority)
	for _, track in ipairs(tracks) do
		if track then
			track.Priority = newPriority
		end
	end
end

local function configureMinigun(client)
	if client.Configuration.ShootType ~= "Minigun" then
		return
	end

	local barrel = client.Tool.Model.Barrel
	local angularVelocity = ReplicatedStorage.AngularVelocity:Clone()
	angularVelocity.Parent = barrel

	local attachment = Instance.new("Attachment")
	attachment.Parent = barrel
	angularVelocity.Attachment0 = attachment
	angularVelocity.MaxTorque = 0

	client.MinigunVelocity = angularVelocity
	client.CurrentShootDebounce = MINIGUN_START_DEBOUNCE
end

local function spinUpMinigun(client)
	if not client.MinigunVelocity then
		return
	end

	client.MinigunVelocity.MaxTorque = MINIGUN_MAX_TORQUE

	task.spawn(function()
		while client.HoldingTrigger and client.CurrentShootDebounce > client.Configuration.ShootDebounce do
			client.CurrentShootDebounce = math.max(
				client.Configuration.ShootDebounce,
				client.CurrentShootDebounce - MINIGUN_DEBOUNCE_STEP
			)
			task.wait(0.1)
		end
	end)
end

local function spinDownMinigun(client)
	if not client.MinigunVelocity then
		return
	end

	client.MinigunVelocity.MaxTorque = 0

	task.spawn(function()
		while not client.HoldingTrigger and client.CurrentShootDebounce < MINIGUN_START_DEBOUNCE do
			client.CurrentShootDebounce = math.min(
				MINIGUN_START_DEBOUNCE,
				client.CurrentShootDebounce + MINIGUN_DEBOUNCE_STEP
			)
			task.wait(0.1)
		end
	end)
end

local function bindInputActions(client)
	if not IS_CLIENT then
		return
	end

	ContextActionService:BindAction(
		"Inspect",
		function(_, state)
			if state ~= Enum.UserInputState.Begin or General.Aiming then
				return
			end

			General.PlayAnimationSet(client.Tracks, "Inspect", true)
		end,
		false,
		Enum.KeyCode.F
	)

	ContextActionService:BindAction(
		"ShootClick",
		function(_, state)
			if state == Enum.UserInputState.Begin then
				client:StartHold()
				return
			end

			if state == Enum.UserInputState.End then
				client:EndHold()
			end
		end,
		false,
		Enum.UserInputType.MouseButton1
	)

	ContextActionService:BindAction(
		"AimState",
		function(_, state)
			if state == Enum.UserInputState.Begin then
				client:Aim()
				return
			end

			if state == Enum.UserInputState.End then
				client:Unaim()
			end
		end,
		false,
		Enum.UserInputType.MouseButton2
	)

	ContextActionService:BindAction(
		"Reload",
		function(_, state)
			if state == Enum.UserInputState.Begin then
				client:Reload()
			end
		end,
		false,
		Enum.KeyCode.R
	)
end

local function unbindInputActions()
	if not IS_CLIENT then
		return
	end

	ContextActionService:UnbindAction("Inspect")
	ContextActionService:UnbindAction("ShootClick")
	ContextActionService:UnbindAction("AimState")
	ContextActionService:UnbindAction("Reload")
end

function Gun.GiveAmmo(ammoType, amount)
	Gun.Ammo[ammoType] += amount
end

function ClientTemplate:Aim()
	if self.AimDebounce or self.Reloading then
		return
	end

	if not General.IsAlive(self.Character.Humanoid) then
		return
	end

	General.PlayAnimationSet(self.Tracks, "Inspect", false)
	General.PlayAnimationSet(self.Tracks, "Aim", true, 0.6)

	if CustomCamera then
		CustomCamera.SensitivityMultiplier = self.Configuration.AimSensitivityMultiplier
	end

	playClientSound(self.Tool.Handle.Audios.Aim, true)
	General.Aiming = true

	if not IS_CLIENT or self.Configuration.ShootType ~= "Sniper" or not self.Player then
		return
	end

	self.Player.PlayerGui.Sniper.Enabled = true
end

function ClientTemplate:Unaim()
	General.PlayAnimationSet(self.Tracks, "Aim", false)

	if CustomCamera then
		CustomCamera.SensitivityMultiplier = 1
	end

	playClientSound(self.Tool.Handle.Audios.Unaim, true)
	General.Aiming = false

	if not IS_CLIENT or self.Configuration.ShootType ~= "Sniper" or not self.Player then
		return
	end

	self.Player.PlayerGui.Sniper.Enabled = false
end

function ClientTemplate:Crosshair(bodyPart, killed)
	if not IS_CLIENT or not self.Player then
		return
	end

	task.spawn(function()
		if self.MainFrame then
			self.MainFrame:Destroy()
		end

		local crosshairGui = self.Player.PlayerGui:WaitForChild("Crosshair")
		local mainFrame = crosshairGui.Template:Clone()
		self.MainFrame = mainFrame
		mainFrame.Parent = crosshairGui

		if killed then
			setFrameProperty(mainFrame, "BackgroundColor3", Color3.fromRGB(163, 0, 0))
		elseif General.HeadCheck(bodyPart) then
			setFrameProperty(mainFrame, "BackgroundColor3", Color3.fromRGB(182, 185, 4))
		end

		mainFrame.Size = CROSSHAIR_START_SIZE
		mainFrame.Visible = true

		TweenService:Create(
			mainFrame,
			TweenInfo.new(0.08, Enum.EasingStyle.Sine),
			{Size = CROSSHAIR_PEAK_SIZE, Rotation = RNG:NextInteger(-10, 10)}
		):Play()

		task.wait(0.08)

		TweenService:Create(
			mainFrame,
			TweenInfo.new(0.04, Enum.EasingStyle.Sine),
			{Size = CROSSHAIR_MIN_SIZE}
		):Play()

		task.wait(0.5)

		if mainFrame.Parent then
			setFrameProperty(mainFrame, "Transparency", 1)
		end
	end)
end

function ClientTemplate:AddToParams(toAdd)
	if not self.Ignore then
		self.Ignore = {self.Character}
	end

	table.insert(self.Ignore, toAdd)

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = self.Ignore
	self.Params = params
end

function ClientTemplate:FireRay(origin, direction, bulletStrength, penetrationDepth)
	bulletStrength = bulletStrength or DEFAULT_BULLET_STRENGTH
	penetrationDepth = penetrationDepth or 0

	if bulletStrength <= 0 or penetrationDepth > MAX_PENETRATIONS then
		return
	end

	direction = direction or self.Camera.CFrame.LookVector
	local rayOrigin = origin or self.Camera.CFrame
	local trailOrigin = origin or self.Tool.Handle.FirePoint.WorldCFrame
	local result = workspace:Raycast(rayOrigin.Position, direction * MAX_RAY_DISTANCE, self.Params)
	local endPosition = result and result.Position or rayOrigin.Position + direction * MAX_RAY_DISTANCE

	runClientEffect("Trail", {trailOrigin, endPosition})
	dispatchEffect(self.Tool, self.Character, "Trail", {trailOrigin, endPosition})

	if not result then
		return
	end

	local hitDistance = (trailOrigin.Position - result.Position).Magnitude
	local hitCharacter = processCharacterHit(
		self,
		result,
		direction,
		bulletStrength,
		hitDistance,
		penetrationDepth
	)

	if hitCharacter then
		return
	end

	processSurfaceHit(self, result, direction, bulletStrength, penetrationDepth)
end

function ClientTemplate:Fire()
	if not canFire(self) then
		return
	end

	General.Shooting = true
	self.ShootDebounce = true

	if Gun.CurrentBullets <= 0 then
		handleEmptyMagazine(self)
		finishShotCooldown(self)
		return
	end

	buildRaycastParams(self)
	fireProjectiles(self)
	updateCrosshairBloom(self)
	playShotAnimation(self)
	emitShotPresentation(self)
	startShootShake(self)
	applyRecoil(self)
	handleSniperPostShot(self)

	Gun.CurrentBullets -= 1
	finishShotCooldown(self)
end

function ClientTemplate:Reload(actionName, state)
	if actionName and (not state or state.Name ~= "Begin") then
		return
	end

	if self.Reloading then
		return
	end

	if not General.IsAlive(self.Character.Humanoid) then
		return
	end

	local ammoType = self.Configuration.AmmoType
	local reserveAmmo = Gun.Ammo[ammoType] or 0
	if reserveAmmo <= 0 then
		return
	end

	local missingBullets = self.Configuration.PerMag - Gun.CurrentBullets
	if missingBullets <= 0 then
		return
	end

	local bulletsToAdd = math.min(missingBullets, reserveAmmo)
	self.Reloading = true

	playClientSound(self.Tool.Handle.Audios.Reload, true)
	dispatchEffect(
		self.Tool,
		self.Character,
		"Sounds",
		nil,
		nil,
		nil,
		{self.Tool.Handle.Audios.Reload, true}
	)

	General.PlayAnimationSet(self.Tracks, "Reload", true)

	if General.Aiming then
		self:Unaim()
	end

	local reloadTrack = self.Tracks.ReloadTrack
	if not reloadTrack then
		self.Reloading = false
		return
	end

	reloadTrack.Stopped:Wait()

	-- Unequipping cancels Reloading while this function is yielded on the animation. Re-checking
	-- the flag here prevents an unequipped weapon from adding ammunition after the reload was cancelled.
	if not self.Reloading then
		return
	end

	Gun.CurrentBullets += bulletsToAdd
	Gun.Ammo[ammoType] -= bulletsToAdd
	self.Reloading = false

	if not IS_CLIENT then
		return
	end

	if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		self:Aim()
	end
end

function ClientTemplate:GetTracks(animationName)
	local animation = self.Tool.GunStuff.Animations:FindFirstChild(animationName)
	if not animation or animation.AnimationId == "" then
		return nil, nil
	end

	local normalTrack = self.Character.Humanoid.Animator:LoadAnimation(animation)
	local armModelTrack

	if IS_CLIENT then
		local armModel = workspace:FindFirstChild("ArmModel")
		if armModel and armModel:FindFirstChild("Humanoid") then
			armModelTrack = armModel.Humanoid.Animator:LoadAnimation(animation)
		end
	end

	return normalTrack, armModelTrack
end

function ClientTemplate:StartAutomaticLoop()
	self.AutomaticLoopVersion += 1
	local loopVersion = self.AutomaticLoopVersion

	task.spawn(function()
		while self.HoldingTrigger and self.Equipped and self.AutomaticLoopVersion == loopVersion do
			self:Fire()
			task.wait()
		end
	end)
end

function ClientTemplate:FireBurst()
	if self.BurstDebounce then
		return
	end

	self.BurstDebounce = true

	task.spawn(function()
		for _ = 1, 3 do
			if not self.HoldingTrigger or not self.Equipped then
				break
			end

			self:Fire()
			task.wait(self.CurrentShootDebounce)
		end

		task.wait(self.Configuration.FiringDebounce)
		self.BurstDebounce = false
	end)
end

function ClientTemplate:FireShotgun()
	if self.ShotgunDebounce then
		return
	end

	self.ShotgunDebounce = true

	task.spawn(function()
		self:Fire()
		task.wait(self.CurrentShootDebounce)
		self.ShotgunDebounce = false
	end)
end

function ClientTemplate:StartHold()
	self.HoldingTrigger = true

	if not self.Equipped then
		return
	end

	local shootType = self.Configuration.ShootType

	if isAutomaticShootType(shootType) then
		self.MadeClickSoundForNoAmmo = false
		self:StartAutomaticLoop()

		if shootType == "Minigun" then
			spinUpMinigun(self)
		end
		return
	end

	if shootType == "Burst" then
		self:FireBurst()
		return
	end

	if shootType == "Shotgun" then
		self:FireShotgun()
		return
	end

	self:Fire()
end

function ClientTemplate:EndHold()
	self.HoldingTrigger = false
	self.AutomaticLoopVersion += 1

	if self.Configuration.ShootType == "Minigun" then
		spinDownMinigun(self)
	end
end

function ClientTemplate:OnEquipped()
	if self.ArmModel then
		self.ArmModel:SetAttribute("Active", true)
	end

	Gun.CurrentBullets = self.StoredBullets
	playClientSound(self.Tool.Handle.Audios.Equip, true)
	General.PlayAnimationSet(self.Tracks, "Idle", true, 0.01)
	General.PlayAnimationSet(self.Tracks, "Equip", true, 0.01)

	self.Equipping = true

	local equipTrack = self.Tracks.EquipTrack
	if equipTrack then
		equipTrack.Stopped:Wait()
	end

	if not self.Equipping then
		return
	end

	self.Equipping = false
	self.Equipped = true
	bindInputActions(self)

	if not IS_CLIENT then
		return
	end

	if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		self:Aim()
	end

	if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
		and isAutomaticShootType(self.Configuration.ShootType)
	then
		self:StartHold()
	end
end

function ClientTemplate:OnUnequipped()
	if self.ArmModel then
		self.ArmModel:SetAttribute("Active", false)
	end

	self.StoredBullets = Gun.CurrentBullets
	self.Equipping = false
	self.Equipped = false
	self.Reloading = false

	self:EndHold()
	stopShootShake(self)
	unbindInputActions()

	playClientSound(self.Tool.Handle.Audios.Reload, false)
	dispatchEffect(
		self.Tool,
		self.Character,
		"Sounds",
		nil,
		nil,
		nil,
		nil,
		{self.Tool.Handle.Audios.Reload}
	)

	for trackName, track in pairs(self.Tracks) do
		if track then
			General.PlayAnimation(track, false, nil, trackName)
		end
	end

	General.PlayAnimationSet(self.Tracks, "Unequip", true)
	General.Aiming = false
	self:Unaim()

	task.wait()

	local newTool = self.Character:FindFirstChildWhichIsA("Tool")
	if not newTool then
		playClientSound(self.Tool.Handle.Audios.Unequip, true)
		return
	end

	if IS_CLIENT and self.Configuration.ShootType == "Sniper" and self.Player then
		self.Player.PlayerGui.Sniper.Enabled = false
	end
end

function Gun.Client(tool, character)
	local client = createClient(tool, character)
	client.Camera = getWeaponCamera(character)
	client.ArmModel = IS_CLIENT and workspace:FindFirstChild("ArmModel") or nil
	client.ShootShakeKey = "ShootShake_" .. tostring(client.Id) .. "_" .. tool.Name
	client.Tracks = loadTracks(client)

	setTrackPriority(
		{client.Tracks.IdleTrack, client.Tracks.ArmModelIdleTrack},
		Enum.AnimationPriority.Action
	)
	setTrackPriority(
		{client.Tracks.EquipTrack, client.Tracks.ArmModelEquipTrack},
		Enum.AnimationPriority.Action4
	)

	configureMinigun(client)

	General.Equipped(tool, function()
		client:OnEquipped()
	end)

	General.Unequipped(tool, function()
		client:OnUnequipped()
	end)

	return client
end

return Gun
