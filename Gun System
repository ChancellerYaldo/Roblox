	local function Action(AnimName)
		local NormalTrack
		local ArmModelTrack
		if Animations:FindFirstChild(AnimName) and Animations[AnimName].AnimationId ~= "" then
			NormalTrack = Humanoid.Animator:LoadAnimation(Animations[AnimName])
		end
		if Animations:FindFirstChild("ArmModel" .. AnimName) and Animations["ArmModel" .. AnimName].AnimationId ~= "" and ArmModel then
			ArmModelTrack = ArmModel.Humanoid.Animator:LoadAnimation(Animations["ArmModel" .. AnimName])
		end

		return NormalTrack, ArmModelTrack 
	end

	local EquipTrack, ArmModelEquipTrack = Action("Equip")
	local UnequipTrack, ArmModelUnequipTrack = Action("Unequip")
	local IdleTrack, ArmModelIdleTrack = Action("Idle")
	local AimTrack, ArmModelAimTrack = Action("Aim")
	local ShootTrack, ArmModelShootTrack = Action("Shoot")
	local ReloadTrack, ArmModelReloadTrack = Action("Reload")
	local HipFireShootTrack, ArmModelHipFireShootTrack = Action("HipFireShoot")
	local InspectTrack, ArmModelInspectTrack = Action("Inspect")
	local JumpTrack, ArmModelJumpTrack = Action("Jump")
	local FallTrack, ArmModelFallTrack = Action("Fall")
