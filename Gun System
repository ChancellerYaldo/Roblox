	Gun.Ammo[Type] += ToAdd
end

local function ClientSound(NPC, Sound, State)
	if not NPC then
		if State then
			Sound:Play()
		else
			Sound:Stop()
		end
	end
end

local function Effects(Tool, NPC, Parameters)
	if not NPC then
		Tool.GunStuff.Events.Other:FireServer(unpack(Parameters))
	else
		Gun.Other(NPC, unpack(Parameters))
	end
end

local function ClientEffects(NPC, GunEffects, Type, Parameters)
	if not NPC then
		GunEffects[Type](unpack(Parameters))
	end
end

function Gun.Client(Tool, NPC)
	local Player = not NPC and game.Players.LocalPlayer
	local Character = NPC or Player.Character
	
	local CustomCamera = not NPC and require(Character.Client.CustomCamera)
	local GunEffects = require(script.GunEffects)
	local CheckPlayerDistance = require(game.ReplicatedStorage.GunFramework.Modules.CheckPlayerDistance)
	local CrosshairModule = not NPC and require(script.Parent:WaitForChild("Crosshair"))
	--local BreakGlass2 = require(game.ReplicatedStorage.FractureGlass)
	--local BreakGlass = require(game.ReplicatedStorage.GunFramework.Modules.BreakGlass)
	
	local StartSize = UDim2.fromScale(.051, .088)
	local PeakSize = UDim2.fromScale(.051 * 2, .088 * 2) 
	local MinSize = UDim2.fromScale(.051 * .75, .088 * .75) 
	local MainFrame = nil
	
	local function Crosshair(BodyPart, Killed)
		if not NPC then
			coroutine.wrap(function()
				if MainFrame then
					MainFrame:Destroy()
				end
			
				MainFrame = Player.PlayerGui:WaitForChild("Crosshair").Template:Clone()
				MainFrame.Parent = Player.PlayerGui.Crosshair
				
				local function ChangeProperty(PropertyName, Value)
					for i, v in pairs(MainFrame:GetChildren()) do
						if v:IsA("Frame") then
							v[PropertyName] = Value
						end
					end
				end
			
				if Killed then
					ChangeProperty("BackgroundColor3", Color3.fromRGB(163, 0, 0))
				elseif HeadCheck(BodyPart) then
					ChangeProperty("BackgroundColor3", Color3.fromRGB(182, 185, 4))
				end
				

				MainFrame.Size = StartSize
				MainFrame.Visible = true
				TweenService:Create(MainFrame, TweenInfo.new(.08, Enum.EasingStyle.Sine), {Size = PeakSize}):Play()
				TweenService:Create(MainFrame, TweenInfo.new(.08, Enum.EasingStyle.Sine), {Rotation = math.random(-10,10)}):Play()
				task.wait(.08)
				TweenService:Create(MainFrame, TweenInfo.new(.04, Enum.EasingStyle.Sine), {Size = MinSize}):Play()
				task.wait(.5)

				ChangeProperty("Transparency", 1)
			end)()
		end
	end
	
	
	
	local Configuration = require(Tool.GunStuff:FindFirstChildWhichIsA("ModuleScript"))
	
	local Equipped = false
	local Reloading = false
	local PerMag = Configuration.PerMag
	local GunAmmo = PerMag
	Gun.CurrentBullets = GunAmmo

	local Humanoid = Character:WaitForChild("Humanoid")
	local HRP = Character:WaitForChild("HumanoidRootPart")
	local Torso = Character:WaitForChild("Torso", 10000000)
	local RightShoulder = Torso:WaitForChild("Right Shoulder", 10000000)
	local OriginalRightShoulderCFrame = RightShoulder.C0
	local LeftShoulder = Torso:WaitForChild("Left Shoulder", 100000)
	local OriginalLeftShoulderCFrame = LeftShoulder.C0
	local Camera = not NPC and workspace.CurrentCamera
	if not Camera then
		Camera = Instance.new("Part")
		Camera.Size = Vector3.zero
		Camera.Transparency = 1
		Camera.Anchored = true
		Camera.CanCollide = false
		Camera.CanTouch = false
		Camera.CanQuery = false
		Camera.CFrame = Character.Head.CFrame
